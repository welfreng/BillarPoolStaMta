rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
    }

    function isSales() {
      return signedIn() &&
        exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'sales';
    }

    match /usuarios/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /siteAssets/{documentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /suppliers/{supplierId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /movements/{movementId} {
      allow read: if signedIn();
      allow create: if isAdmin() || isSales();
      allow update: if isAdmin() || isSales();
      allow delete: if isAdmin();
    }

    match /purchases/{purchaseId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow read: if signedIn();
      allow create: if isAdmin() || isSales();
      allow update: if isAdmin() || isSales();
      allow delete: if isAdmin();
    }
  }
}
