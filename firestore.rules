rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
    }

    function isSales() {
      return signedIn() &&
        exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'sales';
    }

    function isCourier() {
      return signedIn() &&
        exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'courier';
    }

    function isPublicStockSyncUpdate() {
      return resource != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['publicStock', 'updatedAt']);
    }

    match /usuarios/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if signedIn() || (
        resource.data.status == 'active'
      );
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || ((isSales() || isCourier()) && isPublicStockSyncUpdate());
    }

    match /product_variants/{variantId} {
      allow read: if signedIn() || (
        resource.data.status == 'active'
      );
      allow create, update, delete: if isAdmin();
    }

    match /siteAssets/{documentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /suppliers/{supplierId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /movements/{movementId} {
      allow read: if signedIn();
      allow create: if isAdmin() || isSales() || isCourier();
      allow update: if isAdmin() || isSales() || isCourier();
      allow delete: if isAdmin() || isSales();
    }

    match /purchases/{purchaseId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /purchase_items/{itemId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /inventory_movements/{movementId} {
      allow read: if signedIn();
      allow create: if isAdmin() || isSales() || isCourier();
      allow update: if isAdmin() || isSales() || isCourier();
      allow delete: if isAdmin() || isSales();
    }

    match /sales/{saleId} {
      allow read: if signedIn();
      allow create: if isAdmin() || isSales();
      allow update: if isAdmin() || isSales();
      allow delete: if isAdmin() || isSales();
    }

    match /services/{serviceId} {
      allow read: if signedIn();
      allow create: if isAdmin() || isSales();
      allow update: if isAdmin() || isSales();
      allow delete: if isAdmin();
    }

    match /admin-notifications/{notificationId} {
      allow read: if isAdmin();
      allow create: if isAdmin() || isSales() || isCourier();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /authorization-requests/{requestId} {
      allow read: if isAdmin() || isSales();
      allow create: if isAdmin() || isSales();
      allow update: if isAdmin() || isSales();
      allow delete: if isAdmin();
    }

    match /deliveryOrders/{orderId} {
      allow create: if true;
      allow read: if isAdmin() || isSales() || isCourier();
      allow update: if isAdmin() || isSales() || isCourier();
      allow delete: if isAdmin();
    }
  }
}
