rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
        (
          get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin' ||
          get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'superadmin'
        );
    }

    function isSuperAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'superadmin';
    }

    function isSales() {
      return signedIn() &&
        exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'sales';
    }

    function isOwnerBootstrap(userId) {
      return signedIn() &&
        request.auth.uid == userId &&
        request.auth.token.email == 'welfreng@gmail.com' &&
        request.resource.data.uid == userId &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.role == 'superadmin' &&
        request.resource.data.status == 'active';
    }

    function isValidUserRole(role) {
      return role in ['sales', 'admin', 'superadmin'];
    }

    function isValidUserStatus(status) {
      return status in ['active', 'inactive'];
    }

    function isValidUserWrite(userId) {
      return request.resource.data.keys().hasOnly([
          'uid',
          'nombre',
          'email',
          'telefono',
          'role',
          'status',
          'createdAt',
          'updatedAt'
        ]) &&
        request.resource.data.uid == userId &&
        isValidUserRole(request.resource.data.role) &&
        isValidUserStatus(request.resource.data.status);
    }

    function isAdminUserWrite(userId) {
      return isValidUserWrite(userId) &&
        request.resource.data.role in ['sales', 'admin'] &&
        (!exists(/databases/$(database)/documents/usuarios/$(userId)) ||
          get(/databases/$(database)/documents/usuarios/$(userId)).data.role != 'superadmin');
    }

    function isSelfProfileUpdate(userId) {
      return signedIn() &&
        request.auth.uid == userId &&
        resource != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nombre', 'telefono', 'updatedAt']);
    }

    function isPublicStockSyncUpdate() {
      return resource != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['publicStock', 'updatedAt']);
    }

    function isSaleReturnAccountingUpdate() {
      return resource != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'returnedQuantity',
          'returnedSaleAmount',
          'returnedCostAmount'
        ]);
    }

    function isSalesAuthorizationCompletion() {
      return resource != null &&
        resource.data.status == 'approved' &&
        request.resource.data.status == 'completed' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'reviewedBy',
          'completedAt',
          'updatedAt'
        ]);
    }

    match /usuarios/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isOwnerBootstrap(userId) ||
        (isSuperAdmin() && isValidUserWrite(userId)) ||
        (isAdmin() && isAdminUserWrite(userId));
      allow update: if isSelfProfileUpdate(userId) ||
        (isSuperAdmin() && isValidUserWrite(userId)) ||
        (isAdmin() && isAdminUserWrite(userId));
      allow delete: if isSuperAdmin();
    }

    match /products/{productId} {
      allow read: if signedIn() || (
        resource.data.status == 'active'
      );
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isSales() && isPublicStockSyncUpdate());
    }

    match /product_variants/{variantId} {
      allow read: if signedIn() || (
        resource.data.status == 'active'
      );
      allow create, update, delete: if isAdmin();
    }

    match /product_categories/{categoryId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /siteAssets/{documentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /suppliers/{supplierId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /movements/{movementId} {
      allow read: if signedIn();
      allow create: if isAdmin() || isSales();
      allow update, delete: if isAdmin();
    }

    match /purchases/{purchaseId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /purchase_items/{itemId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /inventory_movements/{movementId} {
      allow read: if signedIn();
      allow create: if isAdmin() || isSales();
      allow update, delete: if isAdmin();
    }

    match /sales/{saleId} {
      allow read: if signedIn();
      allow create: if isAdmin() || isSales();
      allow update: if isAdmin() || (isSales() && isSaleReturnAccountingUpdate());
      allow delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if signedIn();
      allow create: if isAdmin() || isSales();
      allow update: if isAdmin() || isSales();
      allow delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if signedIn();
      allow create: if isAdmin() || isSales();
      allow update: if isAdmin() || isSales();
      allow delete: if isAdmin();
    }

    match /service-visits/{visitId} {
      allow read: if signedIn();
      allow create: if isAdmin() || isSales();
      allow update: if isAdmin() || isSales();
      allow delete: if isAdmin();
    }

    match /admin-notifications/{notificationId} {
      allow read: if isAdmin();
      allow create: if isAdmin() || isSales();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /authorization-requests/{requestId} {
      allow read: if isAdmin() || isSales();
      allow create: if isAdmin() || isSales();
      allow update: if isAdmin() || (isSales() && isSalesAuthorizationCompletion());
      allow delete: if isAdmin();
    }

  }
}
