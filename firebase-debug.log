[debug] [2026-04-12T15:45:05.251Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/billarpoolstamta-5d4ac/rulesets {"name":"projects/billarpoolstamta-5d4ac/rulesets/75fce000-eb58-4e85-ba8a-7b79ac6ec1ca","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function isAdmin() {\n      return signedIn() &&\n        exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&\n        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';\n    }\n\n    function isSales() {\n      return signedIn() &&\n        exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&\n        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'sales';\n    }\n\n    function isCourier() {\n      return signedIn() &&\n        exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&\n        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'courier';\n    }\n\n    function isPublicStockSyncUpdate() {\n      return resource != null &&\n        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['publicStock', 'updatedAt']);\n    }\n\n    match /usuarios/{userId} {\n      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());\n      allow create: if signedIn() && (request.auth.uid == userId || isAdmin());\n      allow update: if signedIn() && (request.auth.uid == userId || isAdmin());\n      allow delete: if isAdmin();\n    }\n\n    match /products/{productId} {\n      allow read: if signedIn() || (\n        resource.data.status == 'active'\n      );\n      allow create, delete: if isAdmin();\n      allow update: if isAdmin() || ((isSales() || isCourier()) && isPublicStockSyncUpdate());\n    }\n\n    match /product_variants/{variantId} {\n      allow read: if signedIn() || (\n        resource.data.status == 'active'\n      );\n      allow create, update, delete: if isAdmin();\n    }\n\n    match /product_categories/{categoryId} {\n      allow read: if signedIn();\n      allow create, update, delete: if isAdmin();\n    }\n\n    match /siteAssets/{documentId} {\n      allow read: if true;\n      allow create, update, delete: if isAdmin();\n    }\n\n    match /suppliers/{supplierId} {\n      allow read: if signedIn();\n      allow create, update, delete: if isAdmin();\n    }\n\n    match /movements/{movementId} {\n      allow read: if signedIn();\n      allow create: if isAdmin() || isSales() || isCourier();\n      allow update: if isAdmin() || isSales() || isCourier();\n      allow delete: if isAdmin() || isSales();\n    }\n\n    match /purchases/{purchaseId} {\n      allow read: if signedIn();\n      allow create, update, delete: if isAdmin();\n    }\n\n    match /purchase_items/{itemId} {\n      allow read: if signedIn();\n      allow create, update, delete: if isAdmin();\n    }\n\n    match /inventory_movements/{movementId} {\n      allow read: if signedIn();\n      allow create: if isAdmin() || isSales() || isCourier();\n      allow update: if isAdmin() || isSales() || isCourier();\n      allow delete: if isAdmin() || isSales();\n    }\n\n    match /sales/{saleId} {\n      allow read: if signedIn();\n      allow create: if isAdmin() || isSales();\n      allow update: if isAdmin() || isSales();\n      allow delete: if isAdmin() || isSales();\n    }\n\n    match /services/{serviceId} {\n      allow read: if signedIn();\n      allow create: if isAdmin() || isSales();\n      allow update: if isAdmin() || isSales();\n      allow delete: if isAdmin();\n    }\n\n    match /admin-notifications/{notificationId} {\n      allow read: if isAdmin();\n      allow create: if isAdmin() || isSales() || isCourier();\n      allow update: if isAdmin();\n      allow delete: if isAdmin();\n    }\n\n    match /authorization-requests/{requestId} {\n      allow read: if isAdmin() || isSales();\n      allow create: if isAdmin() || isSales();\n      allow update: if isAdmin() || isSales();\n      allow delete: if isAdmin();\n    }\n\n    match /deliveryOrders/{orderId} {\n      allow create: if true;\n      allow read: if isAdmin() || isSales() || isCourier();\n      allow update: if isAdmin() || isSales() || isCourier();\n      allow delete: if isAdmin();\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-04-12T15:45:05.651103Z","metadata":{"services":["cloud.firestore"]}}
